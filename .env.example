AI_SHIELD_ENV=development
AI_SHIELD_DEBUG=true
AI_SHIELD_HOST=127.0.0.1
AI_SHIELD_PORT=5000
AI_SHIELD_MAX_UPLOAD_MB=50
AI_SHIELD_SECRET_KEY=change-this-in-production

# Optional live-news verification
NEWSAPI_KEY=
AI_SHIELD_NEWS_LOOKUP_DAYS=7
AI_SHIELD_NEWS_LOOKUP_PAGE_SIZE=8
AI_SHIELD_URL_FETCH_TIMEOUT_SECONDS=6
MONGO_URI=
MONGO_DATABASE=ai_shield
AI_SHIELD_TRANSFORMER_MODEL=distilroberta-base
AI_SHIELD_TRANSFORMER_LOCAL_ONLY=false

# Optional external AI assistant
AI_SHIELD_LLM_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_SHIELD_LLM_TIMEOUT_SECONDS=12
